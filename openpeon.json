{
  "cesp_version": "1.0",
  "name": "stronghold-snake",
  "display_name": "The Snake (Stronghold Crusader)",
  "version": "1.0.0",
  "author": { "name": "Marko Jevic", "github": "koyev" },
  "license": "fair-use",
  "language": "en",
  "categories": {
    "session.start": {
      "sounds": [
        { "file": "sounds/sn_add_player.wav", "label": "Laughing" }
      ]
    },
    "task.acknowledge": {
      "sounds": [
        { "file": "sounds/sn_taunt_02.wav", "label": "Presently upon you" },
        { "file": "sounds/sn_taunt_05.wav", "label": "Your death drawing near" }
      ]
    },
    "task.complete": {
      "sounds": [
        { "file": "sounds/sn_vict_01.wav", "label": "You seem to have lost" },
        { "file": "sounds/sn_vict_02.wav", "label": "Am I victorious? Oh yes" },
        { "file": "sounds/sn_vict_04.wav", "label": "Getting rather tiresome" }
      ]
    },
    "task.error": {
      "sounds": [
        { "file": "sounds/sn_anger_01.wav", "label": "Ruining my plans" },
        { "file": "sounds/sn_anger_02.wav", "label": "Not again, sick of your persistence" }
      ]
    },
    "input.required": {
      "sounds": [
        { "file": "sounds/sn_plead_01.wav", "label": "Wanted only to be your ally" },
        { "file": "sounds/sn_plead_02.wav", "label": "Spare my life" }
      ]
    },
    "resource.limit": {
      "sounds": [
        { "file": "sounds/sn_plead_03.wav", "label": "I think I might just..." },
        { "file": "sounds/sn_anger_03.wav", "label": "You severely try my patience" }
      ]
    },
    "user.spam": {
      "sounds": [
        { "file": "sounds/sn_taunt_08.wav", "label": "You're kind of persistent" },
        { "file": "sounds/sn_anger_04.wav", "label": "Who are you to challenge me" },
        { "file": "sounds/sn_kick_player.wav", "label": "Ha!" }
      ]
    }
  }
}
